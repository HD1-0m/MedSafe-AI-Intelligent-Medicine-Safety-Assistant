# AI provider settings for the Python app
# AI_PROVIDER: supported values are 'ollama' (default) or 'gemini'.
AI_PROVIDER="ollama"

# Ollama configuration (used when AI_PROVIDER=ollama)
OLLAMA_MODEL="llama3"

# Gemini configuration (used when AI_PROVIDER=gemini)
GEMINI_API_KEY="MY_GEMINI_API_KEY"
GEMINI_MODEL="gemini-1.5-flash"

# Optional deployment URL
APP_URL="MY_APP_URL"
