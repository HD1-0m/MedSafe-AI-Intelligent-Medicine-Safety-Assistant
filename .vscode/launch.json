{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug MedSafe-AI (Streamlit)",
      "type": "debugpy",
      "request": "launch",
      "module": "streamlit",
      "args": [
        "run",
        "app.py",
        "--server.port=8501",
        "--server.headless=true"
      ],
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "justMyCode": true
    }
  ]
}