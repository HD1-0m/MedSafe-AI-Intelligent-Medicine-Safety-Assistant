# GEMINI_API_KEY: Required when AI_PROVIDER=gemini.
# Configure this via your local environment or .env file.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# AI_PROVIDER: Supported values are 'ollama' (default) or 'gemini'.
AI_PROVIDER="ollama"

# OLLAMA_MODEL: Model name used by the Python AI engine.
OLLAMA_MODEL="llama3"

# APP_URL: Optional app host URL for deployments.
APP_URL="MY_APP_URL"
